def main_tui():
    try:
        email, api_key = get_api_credentials()
        api = MigaduAPI(email, api_key)
        
        def run_tui(stdscr):
            try:
                # Check for minimum terminal size
                height, width = stdscr.getmaxyx()
                if height < 10 or width < 30:
                    stdscr.clear()
                    stdscr.addstr(0, 0, "Terminal too small!")
                    stdscr.addstr(1, 0, "Minimum: 10x30, Current: {}x{}".format(height, width))
                    stdscr.addstr(2, 0, "Press any key to exit...")
                    stdscr.refresh()
                    stdscr.getch()
                    return
                
                tui = MigaduTUI(stdscr)
                tui.show_domains_screen(api)
            except curses.error as e:
                stdscr.clear()
                stdscr.addstr(0, 0, f"Curses error: {e}")
                stdscr.addstr(1, 0, "Press any key to exit...")
                stdscr.refresh()
                stdscr.getch()
                raise
            except Exception as e:
                raise
        
        wrapper(run_tui)
        
    except curses.error as e:
        die(f"TUI curses error: {e}")
    except Exception as e:
        die(f"TUI failed: {e}")

def main():
    if len(sys.argv) > 1:
        arg = sys.argv[1]
        if arg in ['--help', '-h']:
            show_help()
        elif arg in ['--version', '-v']:
            print("Migadu CLI TUI Manager v1.1.0")
        elif arg == '--setup':
            setup_config()
        else:
            log_error(f"Unknown option: {arg}")
            show_help()
            sys.exit(1)
    else:
        main_tui()

if __name__ == "__main__":
    main()